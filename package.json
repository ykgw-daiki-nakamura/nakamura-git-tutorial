{
  "name": "nakamura-git-tutorial",
  "version": "1.0.0",
  "description": "Git / GitHub をチーム開発で実践的に学ぶための図解付きチュートリアルサイト（VitePress + Mermaid）",
  "main": "index.js",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check-nav": "node scripts/check-nav.mjs",
    "check:config": "node scripts/check-config-consistency.mjs",
    "lint:md": "markdownlint-cli2",
    "lint:text": "textlint \"docs/**/*.md\" \"*.md\"",
    "lint:emphasis": "node scripts/check-emphasis.mjs",
    "test:hooks": "bash scripts/test-hooks.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ykgw-daiki-nakamura/nakamura-git-tutorial.git"
  },
  "keywords": [],
  "author": "Daiki Nakamura",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ykgw-daiki-nakamura/nakamura-git-tutorial/issues"
  },
  "homepage": "https://github.com/ykgw-daiki-nakamura/nakamura-git-tutorial#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "markdown-it": "^14.3.0",
    "markdownlint-cli2": "^0.23.0",
    "mermaid": "^11.16.0",
    "textlint": "^15.7.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
