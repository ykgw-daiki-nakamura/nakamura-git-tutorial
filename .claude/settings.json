{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch -a)",
      "Bash(git branch -vv)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git remote -v)",
      "Bash(git remote get-url *)",
      "Bash(git check-ignore *)",
      "Bash(git blame *)",
      "Bash(git worktree list)",
      "Bash(git config --get *)",
      "Bash(git config --list)",
      "Bash(git stash list)",
      "Bash(git tag --list *)",
      "Bash(git tag -l *)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh label list)",
      "Bash(gh label list *)",
      "Bash(gh repo view *)",
      "Bash(npm run lint:md)",
      "Bash(npm run docs:build)",
      "Bash(npm run docs:preview)",
      "Bash(npx markdownlint-cli2 *)"
    ],
    "deny": [
      "Bash(git diff *--output*)",
      "Bash(git diff *-o *)",
      "Bash(git show *--output*)",
      "Bash(git show *-o *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-branch.sh\"",
            "if": "Bash(git commit*)"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-branch.sh\"",
            "if": "Bash(git push*)"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-commit.sh\"",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-edit-check.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pr-watch-handoff.sh\"",
            "if": "Bash(gh pr create*)"
          }
        ]
      }
    ]
  }
}
